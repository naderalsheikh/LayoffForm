<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>SJO Separation Decision Worksheet v2 | Internal Use Only</title>
    <style>
        * { box-sizing: border-box; }
        body {
            background: #e9eef3;
            font-family: 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            margin: 0;
            padding: 2rem 1rem;
            color: #1a2c3e;
        }
        .form-container {
            max-width: 1340px;
            margin: 0 auto;
            background: white;
            border-radius: 24px;
            box-shadow: 0 12px 30px rgba(0,0,0,0.08);
            overflow: hidden;
            border: 1px solid #cfdfed;
        }
        .form-header {
            background: #0b2b3b;
            color: white;
            padding: 1.4rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 0.5rem;
        }
        .form-header h1 { margin: 0; font-weight: 600; font-size: 1.65rem; }
        .header-meta { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
        .internal-badge {
            background: #d1452b;
            padding: 0.25rem 0.8rem;
            border-radius: 30px;
            font-size: 0.72rem;
            font-weight: 700;
            letter-spacing: 0.5px;
        }
        .version-badge {
            background: #1a5276;
            padding: 0.25rem 0.8rem;
            border-radius: 30px;
            font-size: 0.72rem;
            font-weight: 600;
        }
        form { padding: 2rem; }
        fieldset {
            border: 1px solid #d4e0e9;
            border-radius: 20px;
            padding: 1.5rem 1.8rem;
            margin-bottom: 2rem;
            background: #fefefe;
        }
        legend {
            font-weight: 700;
            font-size: 1.2rem;
            background: white;
            padding: 0 1rem;
            color: #0b4f6c;
        }
        .grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(290px, 1fr)); gap: 1.2rem 2rem; }
        .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.2rem 1.5rem; }
        .form-group { margin-bottom: 0.9rem; }
        label {
            display: block;
            font-weight: 600;
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: #2c5a74;
            margin-bottom: 0.3rem;
        }
        input, select, textarea {
            width: 100%;
            padding: 0.65rem 1rem;
            border: 1px solid #cbdde6;
            border-radius: 10px;
            font-size: 0.9rem;
            font-family: inherit;
            background: white;
        }
        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: #2c7da0;
            box-shadow: 0 0 0 3px rgba(44,125,160,0.18);
        }
        input[readonly], select[readonly] {
            background: #f0f6fa;
            color: #4a7a95;
            cursor: default;
        }
        .checkbox-group, .radio-group {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            margin-top: 0.35rem;
            align-items: center;
        }
        .checkbox-group label, .radio-group label {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            font-weight: normal;
            text-transform: none;
            letter-spacing: normal;
            font-size: 0.88rem;
        }
        input[type="checkbox"], input[type="radio"] { width: 1rem; height: 1rem; margin: 0; flex-shrink: 0; }

        /* Employee Card Styles */
        .employee-card {
            background: #f4f8fc;
            border: 2px solid #c8dde9;
            border-radius: 16px;
            padding: 0;
            margin-bottom: 1.5rem;
            position: relative;
            overflow: hidden;
        }
        .employee-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #0b4f6c;
            color: white;
            padding: 0.8rem 1.4rem;
            cursor: pointer;
            user-select: none;
        }
        .employee-card-header .emp-label { font-weight: 700; font-size: 1rem; }
        .employee-card-header .emp-badge {
            font-size: 0.75rem;
            background: rgba(255,255,255,0.15);
            padding: 0.2rem 0.7rem;
            border-radius: 20px;
            margin-left: 0.75rem;
        }
        .employee-card-header .header-actions { display: flex; gap: 0.6rem; align-items: center; }
        .remove-emp-btn {
            background: rgba(209,69,43,0.8);
            border: none;
            padding: 0.25rem 0.85rem;
            border-radius: 20px;
            cursor: pointer;
            font-size: 0.75rem;
            color: white;
            font-weight: 600;
        }
        .toggle-card-btn {
            background: rgba(255,255,255,0.15);
            border: 1px solid rgba(255,255,255,0.3);
            padding: 0.2rem 0.7rem;
            border-radius: 20px;
            cursor: pointer;
            font-size: 0.75rem;
            color: white;
        }
        .employee-card-body { padding: 1.4rem; }

        /* Sub-section headers within employee card */
        .sub-section {
            margin-bottom: 1.4rem;
            padding-bottom: 1.2rem;
            border-bottom: 1px solid #d8eaf3;
        }
        .sub-section:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
        .sub-section-title {
            font-size: 0.72rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #0b4f6c;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .sub-section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #c8dde9;
        }

        /* Conditional fields */
        .conditional-fields {
            background: #fffbe6;
            border: 1px solid #f0d060;
            border-radius: 10px;
            padding: 1rem;
            margin-top: 0.75rem;
        }
        .conditional-fields.blue {
            background: #eff7ff;
            border-color: #aacee8;
        }

        /* Alert / warning boxes */
        .alert {
            border-radius: 12px;
            padding: 0.85rem 1.1rem;
            margin: 0.75rem 0;
            font-size: 0.875rem;
            line-height: 1.5;
        }
        .alert-warning { background: #fef7e0; border-left: 4px solid #e6a017; }
        .alert-danger  { background: #fdecea; border-left: 4px solid #d1452b; }
        .alert-info    { background: #e8f3fb; border-left: 4px solid #2c7da0; }
        .alert-success { background: #e8f6ef; border-left: 4px solid #27ae60; }

        /* Summary dashboard */
        .summary-box {
            background: #e6f3ff;
            border-radius: 12px;
            padding: 1rem 1.3rem;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
            display: flex;
            flex-wrap: wrap;
            gap: 1rem 2.5rem;
        }
        .summary-box .stat { display: flex; flex-direction: column; }
        .summary-box .stat-val { font-size: 1.4rem; font-weight: 800; color: #0b4f6c; }
        .summary-box .stat-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.5px; color: #4a7a95; }

        /* Computed field badge */
        .computed-badge {
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            background: #d0eaf5;
            color: #0b4f6c;
            padding: 0.1rem 0.5rem;
            border-radius: 10px;
            margin-left: 0.4rem;
            vertical-align: middle;
        }

        /* Group roster table */
        .roster-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
        .roster-table th {
            background: #0b4f6c;
            color: white;
            padding: 0.5rem 0.75rem;
            text-align: left;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .roster-table td {
            padding: 0.4rem 0.6rem;
            border-bottom: 1px solid #d4e0e9;
            vertical-align: middle;
        }
        .roster-table tr:nth-child(even) td { background: #f4f8fc; }
        .roster-table input, .roster-table select { padding: 0.3rem 0.6rem; font-size: 0.82rem; border-radius: 6px; }

        /* Buttons */
        button {
            background: #0b4f6c;
            color: white;
            border: none;
            padding: 0.8rem 1.8rem;
            border-radius: 40px;
            font-weight: 600;
            cursor: pointer;
            font-size: 0.88rem;
            transition: 0.2s;
        }
        button:hover { background: #093f56; }
        .btn-secondary { background: #e2edf2; color: #1e4b62; }
        .btn-secondary:hover { background: #cddee6; }
        .btn-sm { padding: 0.4rem 1rem; font-size: 0.8rem; border-radius: 20px; }
        .btn-danger { background: #d1452b; }
        .btn-danger:hover { background: #b33a22; }

        .no-print { display: inline-block; }

        @media print {
            body { background: white; padding: 0; }
            .form-container { box-shadow: none; border: none; }
            .no-print, button, .remove-emp-btn, .toggle-card-btn, #addEmployeeBtn, #addRosterRowBtn { display: none !important; }
            .employee-card { page-break-inside: avoid; }
            fieldset { break-inside: avoid; }
            .employee-card-body { display: block !important; }
        }
    </style>
</head>
<body>
<div class="form-container">
    <div class="form-header">
        <h1>SJO — Separation Decision Worksheet <span class="internal-badge">INTERNAL USE ONLY</span></h1>
        <div class="header-meta">
            <span class="version-badge">v2.0 — Agreement-Ready</span>
            <small id="lastSaved" style="opacity:0.75;">Last saved: —</small>
        </div>
    </div>

    <form id="separationForm">

        <!-- ══════════════════════════════════════════════
             SECTION 1 — RIF OVERVIEW
        ══════════════════════════════════════════════ -->
        <fieldset>
            <legend>📌 RIF Overview</legend>
            <div class="grid-2">
                <div class="form-group">
                    <label for="businessReason">Business reason for reduction *</label>
                    <input type="text" id="businessReason" placeholder="e.g., project completion / economic restructuring / position elimination" required>
                </div>
                <div class="form-group">
                    <label for="decisionalUnit">Decisional unit *</label>
                    <input type="text" id="decisionalUnit" placeholder="e.g., all field supervisors — Terra-Gen Discovery Well project site">
                </div>
                <div class="form-group">
                    <label for="selectionCriteria">Selection criteria used *</label>
                    <input type="text" id="selectionCriteria" placeholder="performance, skills, LIFO, seniority, position elimination">
                </div>
                <div class="form-group">
                    <label for="adverseImpact">Adverse Impact Analysis (summary)</label>
                    <textarea id="adverseImpact" rows="2" placeholder="Summary of demographic review; attach full analysis separately"></textarea>
                </div>
                <div class="form-group">
                    <label for="thirdPartyClient">Third-party client implicated? (Terra-Gen or other)</label>
                    <div class="radio-group">
                        <label><input type="radio" name="thirdPartyClient" value="No" checked> No</label>
                        <label><input type="radio" name="thirdPartyClient" value="Yes"> Yes</label>
                    </div>
                    <input type="text" id="thirdPartyClientName" placeholder="Client name (if yes)" style="margin-top:6px;">
                    <div class="alert alert-warning" id="thirdPartyAlert" style="display:none; margin-top:6px; font-size:0.82rem;">
                        ⚠️ <strong>Counsel note:</strong> Template removes Terra-Gen as third-party beneficiary. Confirm before finalizing whether any client enforcement rights must be reinstated (Sections 10, 12, release scope, property return, confidentiality).
                    </div>
                </div>
                <div class="form-group">
                    <label for="finalizedDate">Date finalized</label>
                    <input type="date" id="finalizedDate">
                </div>
                <div class="form-group">
                    <label for="preparedBy">Prepared by</label>
                    <input type="text" id="preparedBy" placeholder="Name / Role">
                </div>
                <div class="form-group">
                    <label for="approvedBy">Approved by</label>
                    <input type="text" id="approvedBy" placeholder="Name / Title">
                </div>
            </div>
            <div class="alert alert-info" style="margin-top: 0.5rem;">
                <strong>Recital note:</strong> Each agreement's Recital will incorporate the business reason, start date, and compensation description. Confirm language before execution.
            </div>
        </fieldset>

        <!-- ══════════════════════════════════════════════
             SECTION 2 — DECISIONAL UNIT & COMPLIANCE
        ══════════════════════════════════════════════ -->
        <fieldset>
            <legend>👥 Decisional Unit & Compliance Triggers</legend>
            <div class="form-group">
                <label for="rosterSummary">Decisional Unit Roster (summary — all affected employees, titles, hire dates)</label>
                <textarea id="rosterSummary" rows="3" placeholder="List all employees considered, including non-selected, for adverse impact and OWBPA group disclosure purposes"></textarea>
            </div>
            <div class="grid-2">
                <div class="form-group">
                    <label>OWBPA group disclosure required?</label>
                    <div class="radio-group">
                        <label><input type="radio" name="owbpaReq" value="Yes" id="owbpaYes"> Yes (group/exit-incentive program)</label>
                        <label><input type="radio" name="owbpaReq" value="No" id="owbpaNo" checked> No (individual terminations)</label>
                    </div>
                    <div class="alert alert-warning" id="owbpaGroupAlert" style="display:none; margin-top:8px; font-size:0.82rem;">
                        ⚠️ Group program: 45-day consideration period applies to all age-40+ employees. Complete Exhibit C Group Disclosure section below.
                    </div>
                </div>
                <div class="form-group">
                    <label>Cal-WARN / WARN Act implicated?</label>
                    <div class="radio-group">
                        <label><input type="radio" name="warnImp" value="Yes"> Yes</label>
                        <label><input type="radio" name="warnImp" value="No" checked> No</label>
                    </div>
                </div>
                <div class="form-group">
                    <label for="companyHeadcount">Total company headcount</label>
                    <input type="number" id="companyHeadcount" placeholder="Total employees">
                </div>
                <div class="form-group">
                    <label for="siteHeadcount">Headcount at site / establishment</label>
                    <input type="number" id="siteHeadcount" placeholder="Site or location total">
                </div>
                <div class="form-group">
                    <label for="warnWindow">Separations in rolling 30-day window</label>
                    <input type="number" id="warnWindow" placeholder="# of separations">
                </div>
            </div>
            <div class="alert alert-info" style="font-size:0.82rem;">
                <strong>WARN thresholds:</strong> Cal-WARN (Lab. Code § 1400): covered establishment (75+ employees), 50+ separations within 30 days. Federal WARN (29 U.S.C. § 2101): 100+ employees, 50+ separations at a single site.
            </div>
        </fieldset>

        <!-- ══════════════════════════════════════════════
             SECTION 3 — COMPANY-WIDE PAYROLL & WORKERS' COMP
        ══════════════════════════════════════════════ -->
        <fieldset>
            <legend>⚙️ Global Payroll, Insurance & Signatory Data</legend>
            <div class="grid-2">
                <div class="form-group">
                    <label for="workersCompCarrier">Workers' Compensation Carrier (for Exhibit C)</label>
                    <input type="text" id="workersCompCarrier" placeholder="Carrier name, e.g., State Fund, ICW Group">
                </div>
                <div class="form-group">
                    <label for="workersCompPolicy">Workers' Comp Policy Number</label>
                    <input type="text" id="workersCompPolicy" placeholder="Policy #">
                </div>
                <div class="form-group">
                    <label for="finalPayMethod">Default final pay delivery method</label>
                    <select id="finalPayMethod">
                        <option value="">Select</option>
                        <option value="direct deposit">Direct deposit</option>
                        <option value="check">Check (hand-delivered on last day)</option>
                        <option value="check-mailed">Check (mailed same day)</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="sjoSignatory">SJO authorized signatory (for agreements)</label>
                    <input type="text" id="sjoSignatory" placeholder="Full name">
                </div>
                <div class="form-group">
                    <label for="sjoTitle">Title of SJO signatory</label>
                    <input type="text" id="sjoTitle" placeholder="e.g., Managing Member">
                </div>
                <div class="form-group">
                    <label for="sjoSignatoryEmail">Signatory direct email (for § 13(c) notices)</label>
                    <input type="email" id="sjoSignatoryEmail" placeholder="e.g., antonio@sjoperators.com">
                </div>
                <div class="form-group">
                    <label for="sjoSignatoryPhone">Signatory direct phone</label>
                    <input type="tel" id="sjoSignatoryPhone" placeholder="e.g., (661) 555-0100">
                </div>
                <div class="form-group" style="grid-column: span 2;">
                    <label for="sjoNoticeAddress">SJO notice address for § 13(c) (if different from 424 24th St)</label>
                    <input type="text" id="sjoNoticeAddress" placeholder="Leave blank to use registered address: 424 24th Street Suite 7, Bakersfield, CA 93301">
                </div>
                <div class="form-group">
                    <label for="agreementDeliveryMethod">Agreement delivery method</label>
                    <select id="agreementDeliveryMethod">
                        <option value="">Select</option>
                        <option value="hand-delivered">Hand-delivered at meeting</option>
                        <option value="certified-mail">Certified mail</option>
                        <option value="email-pdf">Email PDF + hard copy</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="cobraMailDate">COBRA/HIPP notice mailing date</label>
                    <input type="date" id="cobraMailDate">
                </div>
                <div class="form-group">
                    <label for="adpCorrectionProcessed">ADP payroll correction processed?</label>
                    <div class="radio-group">
                        <label><input type="radio" name="adpCorrectionProcessed" value="Yes"> Yes</label>
                        <label><input type="radio" name="adpCorrectionProcessed" value="No"> No</label>
                        <label><input type="radio" name="adpCorrectionProcessed" value="N/A" checked> N/A</label>
                    </div>
                </div>
            </div>
            <div class="alert alert-info" style="font-size:0.82rem; margin-top:0.5rem;">
                <strong>SJO entity info (pre-filled in template):</strong> San Joaquin Operators, LLC — 424 24th Street Suite 7, Bakersfield, CA 93301 — (661) 866-0219 — EIN: 92-3450088
            </div>
        </fieldset>

        <!-- ══════════════════════════════════════════════
             SECTION 4 — AFFECTED EMPLOYEES
        ══════════════════════════════════════════════ -->
        <fieldset>
            <legend>🧾 Affected Employees <span id="employeeCount" style="font-size:0.9rem;font-weight:400;color:#2c7da0;">(0)</span></legend>

            <div id="summaryDashboard" class="summary-box">
                <div class="stat"><span class="stat-val" id="totalEmployees">0</span><span class="stat-label">Total Employees</span></div>
                <div class="stat"><span class="stat-val" id="over40Count">0</span><span class="stat-label">Age 40+</span></div>
                <div class="stat"><span class="stat-val" id="under40Count">0</span><span class="stat-label">Under 40</span></div>
                <div class="stat"><span class="stat-val" id="totalSeverance">$0</span><span class="stat-label">Est. Total Severance</span></div>
                <div class="stat"><span class="stat-val" id="payrollCorrectionCount">0</span><span class="stat-label">Payroll Corrections</span></div>
                <div class="stat"><span class="stat-val" id="groupTermCount">0</span><span class="stat-label">Group Program</span></div>
            </div>

            <div class="alert alert-warning" id="owbpaWarning" style="display:none;">
                ⚠️ <strong>OWBPA:</strong> One or more employees are age 40+. ADEA release required. Verify: (a) consideration period, (b) 7-day revocation, (c) written advice to consult counsel, (d) disclosure that severance is in addition to amounts otherwise owed.
            </div>
            <div class="alert alert-danger" id="adea40Under" style="display:none;">
                🔴 <strong>Under-40 employees:</strong> ADEA/OWBPA provisions in §§ 2(b)(ii)–(iv) and 6(a) MUST be removed or replaced with a 5-business-day review period. Confirm template version for each under-40 employee.
            </div>

            <div id="employeeContainer"></div>
            <button type="button" id="addEmployeeBtn" class="no-print">+ Add Employee</button>
        </fieldset>

        <!-- ══════════════════════════════════════════════
             SECTION 5 — FINAL PAY READINESS (GLOBAL)
        ══════════════════════════════════════════════ -->
        <fieldset>
            <legend>💰 Final Pay — Ready for Same-Day Delivery?</legend>
            <div class="checkbox-group" style="flex-wrap:wrap;">
                <label><input type="checkbox" id="wagesLastDay"> Wages through last day confirmed</label>
                <label><input type="checkbox" id="ptoPayout"> PTO payout calculated</label>
                <label><input type="checkbox" id="groceryAllowance"> Grocery allowance prorated through last day</label>
                <label><input type="checkbox" id="finalWageStatement"> Final wage statement (IWC Form) ready</label>
                <label><input type="checkbox" id="correctedWageStatements"> Corrected wage statement(s) per Lab. Code § 226 ready (if payroll correction)</label>
            </div>
            <div class="grid-2" style="margin-top:1rem;">
                <div class="form-group">
                    <label>Payroll correction — global status</label>
                    <input type="text" id="payrollCorrectionIssue" placeholder="Describe overall issue, e.g., Jan 2026 exempt salary minimum shortfall">
                </div>
                <div class="form-group">
                    <label>Approximate total correction amount</label>
                    <input type="text" id="payrollCorrectionAmt" placeholder="$ amount (exact per-employee figures entered below)">
                </div>
            </div>
        </fieldset>

        <!-- ══════════════════════════════════════════════
             SECTION 6 — PAYROLL AUDIT
        ══════════════════════════════════════════════ -->
        <fieldset>
            <legend>⚖️ Payroll Audit (Compliance Review)</legend>
            <div class="grid-2">
                <div class="form-group">
                    <label>Exempt employees</label>
                    <div class="checkbox-group" style="flex-direction:column; align-items:flex-start; gap:0.5rem;">
                        <label><input type="checkbox" id="weeklyPayReviewed"> Weekly pay reviewed — no week below § 515 threshold</label>
                        <label><input type="checkbox" id="shortfallIdentified"> Shortfall identified — payroll correction in progress</label>
                    </div>
                </div>
                <div class="form-group">
                    <label>Nonexempt employees</label>
                    <div class="checkbox-group" style="flex-direction:column; align-items:flex-start; gap:0.5rem;">
                        <label><input type="checkbox" id="otReviewed"> OT reviewed (8/40 rule + 7th-day rule)</label>
                        <label><input type="checkbox" id="mealRestReviewed"> Meal/rest premium claims reviewed</label>
                        <label><input type="checkbox" id="bonusesIncluded"> Non-discretionary bonuses & allowances in regular rate</label>
                    </div>
                    <input type="text" id="nonexemptIssueDetails" placeholder="Describe any wage/hour issue" style="margin-top:8px;">
                </div>
            </div>
        </fieldset>

        <!-- ══════════════════════════════════════════════
             SECTION 7 — PROPERTY, CARDS & ACCESS
        ══════════════════════════════════════════════ -->
        <fieldset>
            <legend>📱 Property, Cards & Access</legend>
            <div class="checkbox-group" style="flex-wrap:wrap;">
                <label><input type="checkbox" id="propLaptop"> Laptop</label>
                <label><input type="checkbox" id="propPhone"> Phone</label>
                <label><input type="checkbox" id="propVehicle"> Vehicle (<input type="text" id="vehicleDetails" style="width:130px; display:inline-block; padding:0.2rem 0.5rem;">)</label>
                <label><input type="checkbox" id="propSafety"> Safety equipment</label>
                <label><input type="checkbox" id="propDivvy"> Divvy card</label>
                <label><input type="checkbox" id="propWex"> WEX card</label>
                <label><input type="checkbox" id="propKeys"> Keys/badges</label>
                <label><input type="checkbox" id="propTablet"> Tablet/iPad</label>
                <label><input type="checkbox" id="propCredentials"> Software credentials / passwords</label>
            </div>
            <div class="grid-2" style="margin-top:1rem;">
                <div class="form-group">
                    <label>Unreconciled charges?</label>
                    <div class="radio-group">
