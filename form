                    ${ageLabel ? `<span class="emp-badge">${ageLabel}</span>` : ''}
                    ${adea ? '<span class="emp-badge" style="background:rgba(214,165,0,0.35);">ADEA</span>' : '<span class="emp-badge" style="background:rgba(0,180,0,0.25);">Under 40</span>'}
                    ${emp.terminationType === 'Group' ? '<span class="emp-badge" style="background:rgba(200,100,0,0.35);">Group Program</span>' : ''}
                </span>
                <div class="header-actions">
                    <span class="toggle-card-btn" id="toggleLabel${idx}">▲ Collapse</span>
                    <button type="button" class="remove-emp-btn" onclick="event.stopPropagation(); removeEmployee(${idx})">Remove</button>
                </div>
            </div>
            <div class="employee-card-body" id="cardBody${idx}">

                <!-- ── SECTION A: Identity & Address ── -->
