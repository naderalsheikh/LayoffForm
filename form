                        </div>
                    </div>
                </div>

                <!-- ── SECTION C: Separation Timeline ── -->
                <div class="sub-section">
                    <div class="sub-section-title">C · Separation Timeline &amp; OWBPA Mechanics</div>
                    <div class="grid-3">
                        <div class="form-group">
                            <label>Date of Birth (for age/ADEA)</label>
                            <input type="date" data-field="dob" data-idx="${idx}" value="${emp.dob || ''}">
                        </div>
                        <div class="form-group">
                            <label>Notice / Meeting Date</label>
                            <input type="date" data-field="noticeDate" data-idx="${idx}" value="${emp.noticeDate || ''}">
                        </div>
                        <div class="form-group">
