                        </label>
                    </div>
                    <div class="conditional-fields" id="correctionFields_${idx}" style="${emp.payrollCorrection === 'Yes' ? '' : 'display:none;'}">
                        <div class="alert alert-warning" style="font-size:0.8rem; margin-bottom:0.75rem;">
                            Required fields for Agreement § 1(c) and Exhibit B. Confirm ADP has processed correction and corrected wage statement (Lab. Code § 226) will be issued.
                        </div>
                        <div class="grid-3">
                            <div class="form-group">
                                <label>Correction Amount ($) *</label>
                                <input type="number" step="0.01" data-field="correctionAmount" data-idx="${idx}" value="${emp.correctionAmount || ''}" placeholder="Exact dollar amount">
                            </div>
                            <div class="form-group">
                                <label>Pay Period(s) at Issue *</label>
                                <input type="text" data-field="correctionPayPeriods" data-idx="${idx}" value="${escapeHtml(emp.correctionPayPeriods || '')}" placeholder="e.g., 12/01/2025 – 12/31/2025">
                            </div>
                            <div class="form-group">
                                <label>Correction Payment Date *</label>
                                <input type="date" data-field="correctionPaymentDate" data-idx="${idx}" value="${emp.correctionPaymentDate || ''}">
                            </div>
                            <div class="form-group" style="grid-column: span 2;">
                                <label>Nature of Error (for § 1(c) description)</label>
                                <input type="text" data-field="correctionDescription" data-idx="${idx}" value="${escapeHtml(emp.correctionDescription || '')}" placeholder='e.g., "failure to satisfy California exempt salary minimum effective January 1, 2026"'>
                            </div>
                            <div class="form-group">
                                <label>Corrected Wage Statement Issued?</label>
                                <select data-field="correctedWageStatement" data-idx="${idx}">
                                    <option value="">Select</option>
                                    <option value="Yes" ${emp.correctedWageStatement === 'Yes' ? 'selected' : ''}>Yes</option>
                                    <option value="No - pending" ${emp.correctedWageStatement === 'No - pending' ? 'selected' : ''}>No — pending</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── SECTION E: Severance ── -->
                <div class="sub-section">
                    <div class="sub-section-title">E · Severance (Agreement § 2(a) &amp; Exhibit B)</div>
                    <div class="grid-3">
                        <div class="form-group">
                            <label>Severance Amount ($) *</label>
                            <input type="number" step="0.01" data-field="severance" data-idx="${idx}" value="${emp.severance || ''}" placeholder="Figures">
                        </div>
                        <div class="form-group">
                            <label>Severance Amount in Words *</label>
                            <input type="text" data-field="severanceWords" data-idx="${idx}" value="${escapeHtml(emp.severanceWords || '')}" placeholder='e.g., "Twelve Thousand Five Hundred"'>
                        </div>
                        <div class="form-group">
                            <label>Months of Base Salary Represented *</label>
                            <input type="text" data-field="severanceMonths" data-idx="${idx}" value="${escapeHtml(emp.severanceMonths || '')}" placeholder='e.g., "two (2)"'>
                        </div>
                        <div class="form-group">
                            <label>Severance Structure</label>
                            <select data-field="sevStruct" data-idx="${idx}">
                                <option value="Lump sum" ${emp.sevStruct === 'Lump sum' ? 'selected' : ''}>Lump sum (within 30 days of Effective Date)</option>
                                <option value="Salary continuation" ${emp.sevStruct === 'Salary continuation' ? 'selected' : ''}>Salary continuation</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- ── SECTION F: Benefits & Property ── -->
                <div class="sub-section">
                    <div class="sub-section-title">F · Benefits, Property &amp; Outstanding Items</div>
                    <div class="grid-3">
                        <div class="form-group">
                            <label>Enrolled in Group Health Insurance?</label>
                            <select data-field="healthcareEnrolled" data-idx="${idx}">
                                <option value="Yes" ${emp.healthcareEnrolled === 'Yes' ? 'selected' : ''}>Yes — COBRA notice required</option>
                                <option value="No" ${emp.healthcareEnrolled === 'No' ? 'selected' : ''}>No</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Outstanding Business Expenses? (Lab. Code § 2802)</label>
                            <select data-field="outstandingExpenses" data-idx="${idx}">
                                <option value="No" ${emp.outstandingExpenses === 'No' ? 'selected' : ''}>No</option>
                                <option value="Yes" ${emp.outstandingExpenses === 'Yes' ? 'selected' : ''}>Yes — detail below</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Expense Detail (if yes)</label>
                            <input type="text" data-field="expenseDetails" data-idx="${idx}" value="${escapeHtml(emp.expenseDetails || '')}" placeholder="Amount, description, documentation status">
                        </div>
                    </div>
                    <div style="margin-top:0.5rem;">
                        <label style="font-weight:700; font-size:0.78rem; text-transform:uppercase; letter-spacing:0.5px; color:#2c5a74;">Property to Return (check all that apply)</label>
                        <div class="checkbox-group" style="flex-wrap:wrap; margin-top:0.4rem;">
                            <label><input type="checkbox" data-field="propVehicle" data-idx="${idx}" ${emp.propVehicle ? 'checked' : ''}> Vehicle / Keys</label>
                            <label><input type="checkbox" data-field="propLaptop" data-idx="${idx}" ${emp.propLaptop ? 'checked' : ''}> Laptop</label>
                            <label><input type="checkbox" data-field="propTablet" data-idx="${idx}" ${emp.propTablet ? 'checked' : ''}> Tablet / iPad</label>
                            <label><input type="checkbox" data-field="propPhone" data-idx="${idx}" ${emp.propPhone ? 'checked' : ''}> Phone</label>
                            <label><input type="checkbox" data-field="propDivvy" data-idx="${idx}" ${emp.propDivvy ? 'checked' : ''}> Divvy card</label>
                            <label><input type="checkbox" data-field="propWex" data-idx="${idx}" ${emp.propWex ? 'checked' : ''}> WEX card</label>
                            <label><input type="checkbox" data-field="propBadge" data-idx="${idx}" ${emp.propBadge ? 'checked' : ''}> Access badge / keys</label>
                            <label><input type="checkbox" data-field="propSafety" data-idx="${idx}" ${emp.propSafety ? 'checked' : ''}> Safety equipment</label>
                        </div>
                        <div class="form-group" style="margin-top:0.75rem;">
                            <label>Specific Property Items (for § 4 — list exact items)</label>
                            <input type="text" data-field="propertyList" data-idx="${idx}" value="${escapeHtml(emp.propertyList || '')}" placeholder='e.g., "2021 Ford F-250, VIN ___; Lenovo ThinkPad SN ___; Divvy card x-1234"'>
                        </div>
                    </div>
                </div>

                <!-- ── SECTION G: Notes ── -->
                <div class="sub-section">
                    <div class="sub-section-title">G · Notes &amp; Flags for This Employee</div>
                    <textarea data-field="notes" data-idx="${idx}" rows="2" placeholder="Special instructions, accommodation needs, outstanding questions, drafting flags">${escapeHtml(emp.notes || '')}</textarea>
                </div>

            </div><!-- end card body -->
        `;
        container.appendChild(card);
    });

    attachEmployeeListeners();
    updateSummaryAndWarnings();
}

// ═══════════════════════════════════════════════════
// TOGGLE CARD OPEN/CLOSED
// ═══════════════════════════════════════════════════
function toggleCard(idx) {
    const body = document.getElementById(`cardBody${idx}`);
    const label = document.getElementById(`toggleLabel${idx}`);
    if (!body) return;
    if (body.style.display === 'none') {
        body.style.display = 'block';
        label.textContent = '▲ Collapse';
    } else {
        body.style.display = 'none';
        label.textContent = '▼ Expand';
    }
}

// ═══════════════════════════════════════════════════
// EVENT LISTENERS FOR EMPLOYEE FIELDS
// ═══════════════════════════════════════════════════
function attachEmployeeListeners() {
    document.querySelectorAll('.employee-card-body input, .employee-card-body select, .employee-card-body textarea').forEach(el => {
        el.removeEventListener('change', handleEmpFieldChange);
        el.addEventListener('change', handleEmpFieldChange);
    });
}

function handleEmpFieldChange(e) {
    const el = e.target;
    const idx = parseInt(el.getAttribute('data-idx'));
    const field = el.getAttribute('data-field');
    if (isNaN(idx) || !field || !employees[idx]) return;

    if (el.type === 'checkbox') {
        employees[idx][field] = el.checked ? 'Yes' : 'No';
        // Special case: payroll correction checkbox shows/hides panel
        if (field === 'payrollCorrection') {
            const panel = document.getElementById(`correctionFields_${idx}`);
            if (panel) panel.style.display = el.checked ? 'block' : 'none';
        }
    } else {
        employees[idx][field] = el.value;
    }

    // Recompute dates when relevant fields change
    if (['dob','agreementDeliveryDate','noticeDate','terminationType','signatureDate'].includes(field)) {
        const computed = computeDates(employees[idx]);
        const rdEl = document.getElementById(`reviewDeadline_${idx}`);
        const rvEl = document.getElementById(`revocationDeadline_${idx}`);
        const effEl = document.getElementById(`effectiveDate_${idx}`);
        if (rdEl) rdEl.value = formatDate(computed.reviewDeadline);
        if (rvEl) rvEl.value = formatDate(computed.revocationDeadline);
        if (effEl) effEl.value = formatDate(computed.effectiveDate);
    }

    updateSummaryAndWarnings();
}

function removeEmployee(idx) {
    if (confirm(`Remove ${employees[idx].name || 'this employee'}?`)) {
        employees.splice(idx, 1);
        renderEmployees();
    }
}

// ═══════════════════════════════════════════════════
// SUMMARY DASHBOARD + WARNINGS
// ═══════════════════════════════════════════════════
function updateSummaryAndWarnings() {
    let over40 = 0, under40 = 0, totalSev = 0, correctionCount = 0, groupCount = 0;
    employees.forEach(emp => {
        const age = calculateAge(emp.dob);
        if (age !== null) { if (age >= 40) over40++; else under40++; }
        const sev = parseFloat(emp.severance);
        if (!isNaN(sev)) totalSev += sev;
        if (emp.payrollCorrection === 'Yes') correctionCount++;
        if (emp.terminationType === 'Group') groupCount++;
    });

    const total = employees.length;
    document.getElementById('totalEmployees').innerText = total;
    document.getElementById('over40Count').innerText = over40;
    document.getElementById('under40Count').innerText = under40;
    document.getElementById('totalSeverance').innerText = `$${totalSev.toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2})}`;
    document.getElementById('payrollCorrectionCount').innerText = correctionCount;
    document.getElementById('groupTermCount').innerText = groupCount;
    document.getElementById('employeeCount').innerText = `(${total})`;

    const owbpaSelected = document.querySelector('input[name="owbpaReq"]:checked')?.value === 'Yes';
    document.getElementById('owbpaWarning').style.display = (over40 > 0) ? 'block' : 'none';
    document.getElementById('adea40Under').style.display = (under40 > 0) ? 'block' : 'none';
    document.getElementById('owbpaGroupAlert').style.display = owbpaSelected ? 'block' : 'none';
}

// ═══════════════════════════════════════════════════
// GROUP OWBPA ROSTER
// ═══════════════════════════════════════════════════
let rosterRows = [];

function renderRosterTable() {
    const tbody = document.getElementById('owbpaRosterBody');
    if (!tbody) return;
    tbody.innerHTML = '';
    rosterRows.forEach((row, i) => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td>${i + 1}</td>
            <td><input type="text" value="${escapeHtml(row.name)}" data-roster-field="name" data-roster-idx="${i}" placeholder="Name"></td>
            <td><input type="text" value="${escapeHtml(row.title)}" data-roster-field="title" data-roster-idx="${i}" placeholder="Job title"></td>
            <td><input type="number" value="${row.age || ''}" data-roster-field="age" data-roster-idx="${i}" placeholder="Age" style="width:70px;"></td>
            <td>
                <select data-roster-field="selected" data-roster-idx="${i}">
                    <option value="Yes" ${row.selected === 'Yes' ? 'selected' : ''}>Yes — Selected</option>
                    <option value="No" ${row.selected === 'No' ? 'selected' : ''}>No — Not Selected</option>
                </select>
            </td>
            <td><button type="button" class="btn-sm btn-danger no-print" onclick="removeRosterRow(${i})">✕</button></td>
        `;
        tbody.appendChild(tr);
    });
    document.querySelectorAll('[data-roster-field]').forEach(el => {
        el.addEventListener('change', e => {
            const idx = parseInt(e.target.getAttribute('data-roster-idx'));
            const field = e.target.getAttribute('data-roster-field');
            if (!isNaN(idx) && field) rosterRows[idx][field] = e.target.value;
        });
    });
}

function removeRosterRow(idx) {
    rosterRows.splice(idx, 1);
    renderRosterTable();
}

document.getElementById('addRosterRowBtn')?.addEventListener('click', () => {
    rosterRows.push({ name: '', title: '', age: '', selected: 'Yes' });
    renderRosterTable();
});

// ═══════════════════════════════════════════════════
// GLOBAL RADIO LISTENERS
// ═══════════════════════════════════════════════════
document.querySelectorAll('input[name="owbpaReq"]').forEach(r => r.addEventListener('change', () => {
    const yes = document.querySelector('input[name="owbpaReq"]:checked')?.value === 'Yes';
    document.getElementById('owbpaGroupAlert').style.display = yes ? 'block' : 'none';
    updateSummaryAndWarnings();
}));

document.querySelectorAll('input[name="thirdPartyClient"]').forEach(r => r.addEventListener('change', () => {
    const yes = document.querySelector('input[name="thirdPartyClient"]:checked')?.value === 'Yes';
    document.getElementById('thirdPartyAlert').style.display = yes ? 'block' : 'none';
}));

document.querySelectorAll('input[name="inKindBenefits"]').forEach(r => r.addEventListener('change', () => {
    const yes = document.querySelector('input[name="inKindBenefits"]:checked')?.value === 'Yes';
    document.getElementById('inKindAlert').style.display = yes ? 'block' : 'none';
}));

// ═══════════════════════════════════════════════════
// ADD EMPLOYEE
// ═══════════════════════════════════════════════════
document.getElementById('addEmployeeBtn')?.addEventListener('click', () => {
    employees.push(defaultEmployee());
    renderEmployees();
    // Scroll to new card
    setTimeout(() => {
        const cards = document.querySelectorAll('.employee-card');
        if (cards.length) cards[cards.length - 1].scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 100);
});

// ═══════════════════════════════════════════════════
// COLLECT / POPULATE FORM DATA
// ═══════════════════════════════════════════════════
function collectAllFormData() {
    const formEls = document.querySelectorAll('#separationForm input, #separationForm select, #separationForm textarea');
    const data = { employees, rosterRows };
    formEls.forEach(el => {
        if (el.getAttribute('data-field') || el.getAttribute('data-roster-field')) return; // handled separately
        if (el.type === 'radio') { if (el.checked && el.name) data[el.name] = el.value; }
        else if (el.type === 'checkbox') { if (el.id) data[el.id] = el.checked; }
        else if (el.id && !el.readOnly) { data[el.id] = el.value; }
    });
    return data;
}

function populateFromData(data) {
    if (!data) return;
    if (data.employees && Array.isArray(data.employees)) { employees = data.employees; renderEmployees(); }
    if (data.rosterRows && Array.isArray(data.rosterRows)) { rosterRows = data.rosterRows; renderRosterTable(); }
    for (let [key, val] of Object.entries(data)) {
        if (key === 'employees' || key === 'rosterRows') continue;
        const el = document.getElementById(key);
        if (el) {
            if (el.type === 'checkbox') el.checked = val === true;
            else if (el.type === 'radio') { const r = document.querySelector(`input[name="${key}"][value="${val}"]`); if (r) r.checked = true; }
            else el.value = val;
        } else {
            const rg = document.querySelector(`input[name="${key}"]`);
            if (rg?.type === 'radio') { const r = document.querySelector(`input[name="${key}"][value="${val}"]`); if (r) r.checked = true; }
        }
    }
    updateSummaryAndWarnings();
}

// ═══════════════════════════════════════════════════
// SAVE / LOAD / EXPORT / PRINT
// ═══════════════════════════════════════════════════
document.getElementById('saveDraftBtn')?.addEventListener('click', () => {
    localStorage.setItem('sjoWorksheetDraftV2', JSON.stringify(collectAllFormData()));
    document.getElementById('lastSaved').innerText = `Last saved: ${new Date().toLocaleTimeString()}`;
    alert('Draft saved to browser storage.');
});

document.getElementById('loadDraftBtn')?.addEventListener('click', () => {
    const raw = localStorage.getItem('sjoWorksheetDraftV2');
    if (!raw) { alert('No saved draft found.'); return; }
    try { populateFromData(JSON.parse(raw)); alert('Draft loaded.'); }
    catch(e) { alert('Error loading draft.'); }
});

document.getElementById('exportJsonBtn')?.addEventListener('click', () => {
    const blob = new Blob([JSON.stringify(collectAllFormData(), null, 2)], {type:'application/json'});
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `sjo_separation_worksheet_${new Date().toISOString().slice(0,10)}.json`;
    a.click();
    URL.revokeObjectURL(a.href);
});

document.getElementById('printBtn')?.addEventListener('click', () => window.print());

document.getElementById('resetBtn')?.addEventListener('click', () => {
    if (!confirm('Reset all data? This cannot be undone.')) return;
    employees = [];
    rosterRows = [];
    renderEmployees();
    renderRosterTable();
    document.querySelectorAll('#separationForm input:not([type=radio]):not([type=checkbox]), #separationForm textarea').forEach(el => {
        if (!el.readOnly && !el.getAttribute('data-field') && !el.getAttribute('data-roster-field')) el.value = '';
    });
    document.querySelectorAll('#separationForm input[type=checkbox]').forEach(el => el.checked = false);
    document.querySelectorAll('#separationForm input[type=radio]').forEach(el => {
        if (['No','N/A'].includes(el.value)) el.checked = true;
    });
    updateSummaryAndWarnings();
});

// ═══════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════
renderEmployees();
renderRosterTable();
updateSummaryAndWarnings();
</script>
</body>
</html>
