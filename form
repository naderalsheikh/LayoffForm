                    <div class="sub-section-title">A · Identity, Role & Address</div>
                    <div class="grid-3">
                        <div class="form-group">
                            <label>Salutation</label>
                            <select data-field="salutation" data-idx="${idx}">
                                <option value="Mr." ${emp.salutation === 'Mr.' ? 'selected' : ''}>Mr.</option>
                                <option value="Ms." ${emp.salutation === 'Ms.' ? 'selected' : ''}>Ms.</option>
                                <option value="Mx." ${emp.salutation === 'Mx.' ? 'selected' : ''}>Mx.</option>
                                <option value="Dr." ${emp.salutation === 'Dr.' ? 'selected' : ''}>Dr.</option>
                            </select>
                        </div>
                        <div class="form-group" style="grid-column: span 2;">
                            <label>Full Legal Name (Last, First MI) *</label>
                            <input type="text" data-field="name" data-idx="${idx}" value="${escapeHtml(emp.name)}" placeholder="Last, First Middle">
                        </div>
                        <div class="form-group">
                            <label>Job Title</label>
                            <input type="text" data-field="title" data-idx="${idx}" value="${escapeHtml(emp.title)}" placeholder="Job title">
                        </div>
                        <div class="form-group">
                            <label>Site / Location</label>
                            <input type="text" data-field="site" data-idx="${idx}" value="${escapeHtml(emp.site)}" placeholder="Project site or location">
                        </div>
                        <div class="form-group">
                            <label>Exempt / Nonexempt</label>
                            <select data-field="exemptStatus" data-idx="${idx}">
                                <option value="">Select</option>
                                <option value="Exempt" ${emp.exemptStatus === 'Exempt' ? 'selected' : ''}>Exempt (Salaried)</option>
                                <option value="Nonexempt" ${emp.exemptStatus === 'Nonexempt' ? 'selected' : ''}>Nonexempt (Hourly)</option>
                            </select>
                        </div>
                        <div class="form-group" style="grid-column: span 2;">
                            <label>Home Address Line 1 (for cover letter &amp; Exhibit C) *</label>
                            <input type="text" data-field="address1" data-idx="${idx}" value="${escapeHtml(emp.address1)}" placeholder="Street address">
                        </div>
                        <div class="form-group">
                            <label>Address Line 2</label>
                            <input type="text" data-field="address2" data-idx="${idx}" value="${escapeHtml(emp.address2)}" placeholder="City, State ZIP">
                        </div>
                        <div class="form-group">
                            <label>SSN Last 4 Digits (Exhibit C only)</label>
                            <input type="text" data-field="ssnLast4" data-idx="${idx}" value="${escapeHtml(emp.ssnLast4)}" placeholder="XXXX" maxlength="4">
                        </div>
                        <div class="form-group">
                            <label>Employee Phone (§ 13(c) notices &amp; follow-up)</label>
                            <input type="tel" data-field="empPhone" data-idx="${idx}" value="${escapeHtml(emp.empPhone || '')}" placeholder="(xxx) xxx-xxxx">
                        </div>
                        <div class="form-group">
                            <label>Employee Personal Email (§ 13(c) notices)</label>
                            <input type="email" data-field="empEmail" data-idx="${idx}" value="${escapeHtml(emp.empEmail || '')}" placeholder="Personal — not SJO work account">
                        </div>
                        <div class="form-group">
                            <label>Preferred delivery method</label>
                            <select data-field="empContactPref" data-idx="${idx}">
                                <option value="">Select</option>
                                <option value="In-person meeting" ${emp.empContactPref === 'In-person meeting' ? 'selected' : ''}>In-person meeting</option>
                                <option value="Phone + email" ${emp.empContactPref === 'Phone + email' ? 'selected' : ''}>Phone + email</option>
                                <option value="Certified mail" ${emp.empContactPref === 'Certified mail' ? 'selected' : ''}>Certified mail</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Language / interpreter needed?</label>
                            <input type="text" data-field="empLanguage" data-idx="${idx}" value="${escapeHtml(emp.empLanguage || '')}" placeholder="e.g., Spanish — interpreter arranged">
                        </div>
                    </div>
                    <div class="alert alert-info" style="font-size:0.8rem; margin-top:0.5rem;">
                        <strong>§ 13(c) notice reminder:</strong> OWBPA revocation must be delivered in writing to SJO before the 7-day period expires. Ensure the employee receives the signatory's direct contact details at agreement delivery.
                    </div>
                </div>

                <!-- ── SECTION B: Employment History & Compensation ── -->
                <div class="sub-section">
                    <div class="sub-section-title">B · Employment History &amp; Compensation</div>
                    <div class="grid-3">
                        <div class="form-group">
                            <label>Start / Hire Date *</label>
                            <input type="date" data-field="startDate" data-idx="${idx}" value="${emp.startDate || ''}">
                        </div>
                        <div class="form-group">
                            <label>Compensation Type</label>
                            <select data-field="compType" data-idx="${idx}">
                                <option value="Salary" ${emp.compType === 'Salary' ? 'selected' : ''}>Salary (Exempt)</option>
