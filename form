                        </div>
                        <div class="form-group">
                            <label>Hourly Rate (if nonexempt, for Exhibit C)</label>
                            <input type="number" step="0.01" data-field="hourlyRate" data-idx="${idx}" value="${emp.hourlyRate || ''}" placeholder="$/hour">
                        </div>
                        <div class="form-group" style="grid-column: span 2;">
                            <label>Compensation Description (for Agreement recital &amp; § 1(a)) *</label>
