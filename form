<script>
// ═══════════════════════════════════════════════════
// EMPLOYEE DATA MODEL
// ═══════════════════════════════════════════════════
let employees = [];

const defaultEmployee = () => ({
    // Identity & Role
    name: '', salutation: 'Mr.', title: '', site: '', exemptStatus: '',
    // Address
    address1: '', address2: '',
    // Employment History
    startDate: '', compType: 'Salary', annualSalary: '', hourlyRate: '',
    // Separation Timeline
    dob: '', noticeDate: '', adminLeave: '', lastDay: '', agreementDeliveryDate: '',
    reviewPeriodType: '', reviewDeadline: '', signatureDate: '', revocationDeadline: '', effectiveDate: '',
    // Final Pay
    hoursWorked: '', ptoPayout: '', finalWagesAmount: '', finalPayMethodEmp: '',
    // Payroll Correction
    payrollCorrection: 'No', correctionAmount: '', correctionPayPeriods: '', correctionPaymentDate: '',
    // Severance
    severance: 0, severanceWords: '', severanceMonths: '', sevStruct: 'Lump sum',
    // Benefits & Insurance
    healthcareEnrolled: 'No', ssnLast4: '', outstandingExpenses: 'No', expenseDetails: '',
    // Agreement Type
    terminationType: 'Individual',
    // Misc
    notes: '',
    // Contact
    empPhone: '', empEmail: '', empContactPref: '', empLanguage: ''
});

// ═══════════════════════════════════════════════════
// UTILITY FUNCTIONS
// ═══════════════════════════════════════════════════
function calculateAge(dobStr) {
    if (!dobStr) return null;
    const birth = new Date(dobStr);
    const today = new Date();
    let age = today.getFullYear() - birth.getFullYear();
    const m = today.getMonth() - birth.getMonth();
    if (m < 0 || (m === 0 && today.getDate() < birth.getDate())) age--;
    return age;
}

function addBusinessDays(dateStr, days) {
    if (!dateStr) return '';
    let date = new Date(dateStr);
    let count = 0;
    while (count < days) {
        date.setDate(date.getDate() + 1);
        const dow = date.getDay();
        if (dow !== 0 && dow !== 6) count++;
    }
    return date.toISOString().slice(0, 10);
}

function addCalendarDays(dateStr, days) {
    if (!dateStr) return '';
    const date = new Date(dateStr);
    date.setDate(date.getDate() + days);
    return date.toISOString().slice(0, 10);
}

function formatDate(isoStr) {
    if (!isoStr) return '';
    const [y, m, d] = isoStr.split('-');
    return `${m}/${d}/${y}`;
}

function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>'"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[c]));
}

function getReviewPeriodType(emp) {
    const age = calculateAge(emp.dob);
    const isGroup = emp.terminationType === 'Group';
    if (age === null) return '';
    if (age < 40) return 'Under 40 (5 business days)';
    if (isGroup) return '40+ Group program (45 calendar days + 7-day revocation)';
    return '40+ Individual (21 calendar days + 7-day revocation)';
}

function computeDates(emp) {
    const age = calculateAge(emp.dob);
    const delivDate = emp.agreementDeliveryDate || emp.noticeDate;
    let reviewDeadline = '', revocationDeadline = '', effectiveDate = '';

    if (age !== null && delivDate) {
        if (age < 40) {
            reviewDeadline = addBusinessDays(delivDate, 5);
        } else if (emp.terminationType === 'Group') {
            reviewDeadline = addCalendarDays(delivDate, 45);
        } else {
            reviewDeadline = addCalendarDays(delivDate, 21);
        }
    }

    if (emp.signatureDate) {
        revocationDeadline = addCalendarDays(emp.signatureDate, 7);
        effectiveDate = addCalendarDays(emp.signatureDate, 7);
    }

    return { reviewDeadline, revocationDeadline, effectiveDate };
}

// ═══════════════════════════════════════════════════
// RENDER EMPLOYEE CARDS
// ═══════════════════════════════════════════════════
function renderEmployees() {
    const container = document.getElementById('employeeContainer');
    if (!container) return;
    container.innerHTML = '';

    employees.forEach((emp, idx) => {
        const age = calculateAge(emp.dob);
        const ageLabel = age !== null ? `Age ${age}` : '';
        const adea = age !== null && age >= 40;
        const computed = computeDates(emp);
        const reviewType = getReviewPeriodType(emp);

        const card = document.createElement('div');
        card.className = 'employee-card';
        card.innerHTML = `
            <div class="employee-card-header" onclick="toggleCard(${idx})">
                <span>
