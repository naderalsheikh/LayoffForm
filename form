                    </div>
                    <div class="grid-3" style="margin-top:0.5rem;">
                        <div class="form-group">
                            <label>Review Period Type <span class="computed-badge">Auto</span></label>
                            <input type="text" readonly value="${escapeHtml(reviewType)}" style="background:#f0f6fa; color:#4a7a95;">
